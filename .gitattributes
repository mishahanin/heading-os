# ---------------------------------------------------------------------------
# LFS-tracked binary types. KEEP these lines at the top of the file - the
# `filter=lfs` attribute must be set BEFORE the later `*.gif binary` /
# `* text=auto` rules so LFS interception still fires (git applies the first
# matching attribute line per attribute name). Adding a new binary extension
# below in the `binary` section will NOT route it through LFS; if you need
# LFS for a new type, add it HERE as
#     *.ext filter=lfs diff=lfs merge=lfs -text
# Verify with: git check-attr -a -- path/to/file.ext (look for filter: lfs).
# ---------------------------------------------------------------------------
*.pptx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text

# ---------------------------------------------------------------------------
# Line endings — cross-platform compatibility (Phase 0.1, audit 2026-05-23)
# Source: outputs/operations/workspace/2026-05-23_audit_cross-platform-compatibility.md
# ---------------------------------------------------------------------------

# Default: detect text, normalise to LF in the repo, deliver native on checkout
* text=auto

# Explicit LF for every file Linux/WSL/macOS will execute or read as source
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.env.example text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.socket text eol=lf

# Windows-only scripts keep CRLF — cmd.exe and PowerShell need it
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.vbs text eol=crlf
*.reg text eol=crlf

# Fonts — binary, never normalise
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary

# Additional binary types not in LFS
*.gif binary
*.ico binary
*.webp binary
*.gz binary
*.tar binary
*.7z binary
*.dotx binary
*.xlsb binary
*.db binary
*.sqlite binary
*.sqlite3 binary
scripts/knowledge-health.py text eol=lf
scripts/linkedin-archive.py text eol=lf
scripts/marp_render.py text eol=lf
scripts/md-to-docx-proposal.py text eol=lf
scripts/merge-contacts.py text eol=lf
scripts/offboard-exec.py text eol=lf
