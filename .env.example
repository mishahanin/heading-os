# HEADING OS Workspace - Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env - only .env.example is tracked

# --- GitHub / backup ---
# Token used for all git push / backup auth (push-all.py). Without it,
# backups cannot authenticate. Needs repo scope (and workflow scope if you
# push GitHub Actions workflow files).
GH_TOKEN=ghp_your-token-here

# --- Data overlay path ---
# Absolute path to your private data repository. Only needed if the sibling
# .heading-os-data is not auto-discovered next to the engine clone.
# HEADING_OS_DATA=/abs/path/to/.heading-os-data

# --- Exchange (Corporate Email) ---
EXCHANGE_EMAIL=your.email@example.com
EXCHANGE_PASSWORD=your_exchange_password_here
EXCHANGE_SERVER=mail.example.com

# --- Optional Exchange Settings ---
# EXCHANGE_USERNAME=your.email@example.com
# EXCHANGE_AUTH_TYPE=NTLM
# EXCHANGE_TIMEZONE=UTC

# --- Per-instance local timezone ---
# IANA name used for timestamps, calendar, and daemon scheduling.
# Engine default is UTC; set this to your operating timezone.
# HEADING_OS_TZ=UTC

# --- AI APIs ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Ollama cloud models (optional) ---
# Local embeddings (bge-m3 for /recall) need NO key. This is only for
# Ollama-hosted cloud reasoning models used by /council and /deep-research-advance.
# OLLAMA_API_KEY=your-ollama-cloud-key-here
PERPLEXITY_API_KEY=pplx-your-key-here
CONTEXT7_API_KEY=your-context7-key-here

# --- Image Generation ---
REPLICATE_API_TOKEN=r8_your-token-here

# --- Telegram Client ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# --- Web Scraping ---
FIRECRAWL_API_KEY=fc-your-key-here

# --- Web Search (entity resolution, /osint Phase 0.5) ---
# Tavily: signup at https://tavily.com (free tier: 1,000 credits/month)
# Brave Search API: signup at https://brave.com/search/api/ (free tier: 2,000 queries/month)
# Tavily is primary; Brave is the automatic fallback.
TAVILY_API_KEY=tvly-your-key-here
BRAVE_API_KEY=BSA-your-key-here

# --- OSINT / Breach Intelligence ---
DEHASHED_EMAIL=your.email@example.com
DEHASHED_API_KEY=your-dehashed-key-here
HIBP_API_KEY=your-hibp-key-here
HUNTER_API_KEY=your-hunter-key-here
VIRUSTOTAL_API_KEY=your-virustotal-key-here
