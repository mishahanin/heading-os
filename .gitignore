# Secrets - NEVER commit
.env
.env.*
!.env.example

# Platform-specific settings. Each OS has a TRACKED template
# (settings.local.linux.json / .macos.json / .windows.json) that seeds the
# machine-local live file. The live .claude/settings.local.json is machine-local
# (absolute paths, per-machine permission allow-lists) and is NEVER tracked in
# the engine repo (code-only, eventually public). To change shipped hook wiring,
# edit the per-OS templates; the live file is regenerated per machine.
.claude/settings.local.json

# Python
__pycache__/
*.pyc
*.pyo

# pytest-cov artifacts (generated by integration tests)
.coverage
.coverage.*
coverage.xml
htmlcov/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Clipboard images (transient screenshots via cv command)
outputs/clipboard/

# Telegram group backup artifacts (transient sweep outputs - JSON dumps,
# downloaded media, throwaway helper scripts). Per-session, never reused.
outputs/telegram-groups-backup/

# Browser cookies (imported via /setup-browser-cookies, contains secrets)
outputs/browser/cookies.json

# Chromium profile cache (ephemeral browser data from Playwright)
outputs/browser/chrome-profile/

# Chromium profile caches in other output subdirs (e.g. Comet CDP automation)
outputs/**/.profile/

# LinkedIn scrape artifacts (authenticated DOM dumps, may contain PII)
outputs/browser/linkedin-*.html
outputs/browser/linkedin-*.md
outputs/browser/linkedin-*.json
outputs/browser/li-debug.*

# Service sessions (auth tokens, runtime state)
.sessions/

# Sentinel runtime (state, logs, PID)
.sentinel/

# Editor files
*.swp
*.swo
*~
.zed/

.agent/
.agents/
.kiro/

# MobaXterm workspace artifacts (legacy, kept as safeguard)
Desktop
LauncherFolder
MyDocuments
slash/

# Multi-user HEADING OS ecosystem
.workspace-identity.json
# ...but test fixtures ship their own identity files on purpose -- the broad rule
# above must not strip them from a fresh clone, or tests/integration/test_setup_wizard_e2e.py
# fails with audience misdetection ('public' instead of 'exec') on any clean checkout.
!tests/fixtures/**/.workspace-identity.json
.corporate-repo/
.crm-central-repo/
.sync/
.heartbeat.json

# Firecrawl cache (scraped web content, potentially sensitive)
outputs/browser/firecrawl-cache/

# DocParse cache (parsed document data, regenerated on demand)
.cache/docparse/

# Auto-generated sync state (calendar, email, linkedin) - moved out of datastore in restructure
outputs/_sync/

# MARP renders (binary/large; regenerable from source)
outputs/deliverables/presentations/*.pdf
outputs/deliverables/presentations/*.html
outputs/deliverables/presentations/*.png
# but keep MARP source .md files tracked
!outputs/deliverables/presentations/marp-source/
!outputs/deliverables/presentations/marp-source/**

# Scheduled tasks runtime state
.claude/scheduled_tasks.json
.claude/scheduled_tasks.lock

# Scratch / work-in-progress area
.tmp/

# Browser preference backups (high-entropy browser data, not secrets)
outputs/operations/system/backups/

# Email intelligence transient runtime files (regenerated each run; high-entropy Exchange message IDs)
outputs/operations/email-intelligence/_*
outputs/operations/email-intelligence/state.json

# Office lock/owner files (Word/PowerPoint/Excel temp)
~$*

# DocParse raw outputs (regenerable; may contain sensitive scraped data)
outputs/intel/docparse/

# Sensitive closed-project archives relocated from the removed _secure/ vault
# (Plan 5). CEO-Eyes-Only deliverables — present on disk under the data root,
# never tracked in any git history. Carried into the data overlay at cutover.
outputs/projects/

# Atticus book-writing backups (contain JWT session tokens)
**/atticus-backup-*.json

# Secure vault (CEO Eyes Only - total air-gap, never committed)
_secure/

# Setup wizard state (PII, per-machine)
.setup/

# Migration mirror clones (full git history backups, regeneratable from origin)
outputs/operations/migrations/*.git/

# CRM aggregation outputs (CEO-local, derivative — regenerated by aggregate-crm.py)
crm/aggregated/

# Working scratch dir for skills (drafts, helper scripts, intermediate artifacts)
outputs/_tmp/
outputs/_temp/
outputs/_yt_tmp/
scripts/_scratch/

# Superpowers plugin runtime state (brainstorm cache, etc.)
.superpowers/

# CEO internal design/plan/spec archive — routes `private`, lives in the DATA
# overlay (.heading-os-data/docs/superpowers/), never in the engine clone.
# (4 files were misrouted here and moved out 2026-06-22; this keeps them out.)
docs/superpowers/

# Git worktrees (per superpowers:using-git-worktrees skill)
.worktrees/

# Personal threads - CEO-only, never committed (per docs/superpowers/specs/2026-04-29-threads-registry-design.md)
threads/personal/
threads/archive/**/personal/

# Isolated venv for Tribe Fireside daemon (pinned deps, prevents system-Python rot)
scripts/.venv-fireside/

# Sync-Exchange daemon runtime dir (PID, log, sentinel)
.sync-exchange/

# Fireside daemon runtime dir (PID, log, sentinel) - was missing
.fireside/

# Bridge daemon investor send-tracking log (CEO-only operational state; may
# carry sensitive notes about outreach channels/recipients)
outputs/operations/fundraising/**/_send-log.jsonl

# Bridge daemon pipeline touch-tracking log (CEO-only operational state;
# notes may reference channels/people on specific deals)
outputs/operations/pipeline/_touch-log.jsonl

# Bridge daemon inbox dismiss log (CEO-only operational state; carries
# Exchange conversation IDs which are high-entropy + potentially sensitive)
outputs/operations/email-intelligence/_dismiss-log.jsonl

# CRM migration staging + backup (Phase 0 - one-shot, not tracked)
crm/.migration-staging/
crm/.migration-backup/

# Eval-drift daemon runtime (PID, rotated log, stop sentinel) - P2.2
.eval-drift/

# Living Interface Bridge daemon runtime (token, port, telemetry, rotating log)
.daemon-state/
# Generated by scripts/install-bridge-service.ps1 - regenerated on each install
scripts/launch-bridge-daemon.bat


# Service-host state mirror - frequently regenerated; not source-of-truth
datastore/operations/service-mirror/

# Daemon runtime state files (per-machine, continuously rewritten - tracked
# historically but causes /push-updates noise on every commit). Migration
# 2026-05-24 per /scrutinize M5(b). The surrounding directories still contain
# tracked CONTENT (rosters, configs, schedules, daily reports) that stays.
.claude/state/dispatch-rate.json
.claude/state/checkpoint-state.json
.claude/state/*.tmp
datastore/operations/eval-drift/errors.log
datastore/operations/eval-drift/state.json
datastore/operations/tribe/fireside-state/dm-log.jsonl
datastore/operations/tribe/fireside-state/errors.log
datastore/operations/tribe/fireside-state/last-update-id.json
datastore/operations/tribe/fireside-state/sessions.jsonl
outputs/operations/tribe-fireside/pulse-checkpoint.json

# Fundraising build intermediates (regenerated by build pipeline; investor
# briefings themselves are tracked, _build/ are throwaway artifacts)
outputs/operations/fundraising/**/_build/

# Local associative-memory index (rebuildable cache, per-machine, not source-of-truth)
.memory-index/
# Engine-side code index (skill/rule layers; rebuildable cache, per-machine)
.memory-index-code/

# Odin /odin collect recency marker (per-machine, rebuildable -- absence widens the --since window)
knowledge/odin-brain/.last-collect
.git/hooks/

# Action Queue runtime state (R1, 2026-06-03): the daemon-written card store +
# audit log. Per-machine, continuously rewritten, carries private draft bodies +
# recipient addresses - never committed (the daemon recreates an empty store).
outputs/operations/action-queue/queue.json
outputs/operations/action-queue/disposition-log.jsonl

# Dead-letter queue runtime artifacts (R14, 2026-06-04): failed-finalizer
# records keyed by trace_id, carrying recipient + body payloads (mode 0600).
# CEO-local, never committed.
outputs/operations/dead-letter

# /implement run artifacts - transient per-run tmp + trajectory logs. Keep the
# _tmp/.gitkeep, ignore its contents and the trajectory jsonl files.
outputs/operations/implement/_tmp/*
!outputs/operations/implement/_tmp/.gitkeep
outputs/operations/implement/_trajectory_*.jsonl

# Per-skill personal customization overrides (BMAD Wave 1). The team layer
# ({skill}.toml) is committed and corporate-synced; the personal layer is local-only.
config/skill-custom/*.user.toml

# memlog working-memory files (BMAD Wave 1). Append-only session memory backing
# long-running skills (/deal-strategy, /linkedin-series); the deliverable is derived
# from it, the .memlog.md itself is transient and never committed.
**/.memlog.md


# Eval-capture staged drafts (R13). Scratch only - inert until the CEO promotes
# one into evals/outcomes/ and commits it. Kept untracked so a captured CEO-private
# draft can never be shipped by publish-corporate (tracked-only) nor trip its
# untracked-corporate-file block. Discoverable via `eval-flag.py --list`.
**/evals/outcomes/_staged/

# HEADING OS: data dirs never belong in the engine (data lives in
# the .heading-os-data sibling; resolved via get_*_dir()).
/threads/
/crm/
/outputs/
/knowledge/
/context/
/plans/
/datastore/
/_archive/

# Exec-workspace overlay / local trees. The legacy two-layer copies (corporate/,
# personal/) must never be tracked in the engine repo: corporate content is now
# read directly from .corporate-repo/ (the gitignored heading-os-corporate clone,
# above), and an exec's private data lives in the data overlay. No-op on the CEO
# clone (neither dir exists there); protective on every exec clone.
/corporate/
/personal/

# safe-push.py live status files (runtime, observable, rebuildable)
.push-state/

# Proprietary fonts — licensed (GT Standard / Grilli Type, 31C custom), NOT
# redistributable in a public repo. Adopters supply their own; see the README in
# the fonts dir. The marp theme references these by path and degrades to a
# system fallback when they are absent.
.claude/skills/marp/themes/fonts/GT-Standard-*.woff2
.claude/skills/marp/themes/fonts/31CHorizontalT03-*.woff2
